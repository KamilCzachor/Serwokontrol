DirectoryIndex index.html
RewriteEngine On

# Zapobiega automatycznemu dopasowywaniu adresow do plikow .html.
<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

# Kanoniczne adresy bez rozszerzenia .html.
# THE_REQUEST sprawia, ze przekierowanie dotyczy tylko adresu wpisanego
# przez uzytkownika, a nie wewnetrznych przepisanych zadania.
RewriteCond %{THE_REQUEST} \s/+index\.html(?:[?\s]) [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+about\.html(?:[?\s]) [NC]
RewriteRule ^about\.html$ /o-nas [R=301,L]

RewriteCond %{THE_REQUEST} \s/+contact\.html(?:[?\s]) [NC]
RewriteRule ^contact\.html$ /kontakt [R=301,L]

RewriteCond %{THE_REQUEST} \s/+products\.html(?:[?\s]) [NC]
RewriteRule ^products\.html$ /produkty [R=301,L]

RewriteCond %{THE_REQUEST} \s/+privacy\.html(?:[?\s]) [NC]
RewriteRule ^privacy\.html$ /polityka-prywatnosci [R=301,L]

# Starsze adresy przekierowujemy bezposrednio na adresy kanoniczne.
RewriteRule ^systemy-kontroli-plynow/?$ /produkty [R=301,L]
RewriteRule ^systemy-kontroli-plynow/produkty/?$ /produkty [R=301,L]
RewriteRule ^systemy-kontroli-plynow/burkert/?$ /produkty [R=301,L]
RewriteRule ^hydraulika-silowa-serwonapedy/?$ /produkty [R=301,L]
RewriteRule ^hydraulika-silowa-serwonapedy/moog/?$ /produkty [R=301,L]
RewriteRule ^hydraulika-silowa-serwonapedy/uslugi/?$ /kontakt [R=301,L]
RewriteRule ^polityka-cookies/?$ /polityka-prywatnosci [R=301,L]

# Wewnetrzna obsluga przyjaznych adresow przez istniejace pliki HTML.
# Adres w przegladarce pozostaje bez rozszerzenia.
RewriteRule ^o-nas/?$ about.html [END]
RewriteRule ^kontakt/?$ contact.html [END]
RewriteRule ^produkty/?$ products.html [END]
RewriteRule ^polityka-prywatnosci/?$ privacy.html [END]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com 'sha256-XQ8QtJ5ye3RCRo8E1UCJMJMafNnTmptaEMi9lt1qz0o=' 'sha256-pnkf4ZGNoTwAWS0hp6npaNBayKT3iydc8KZv+kZxkhI=' 'sha256-6mS1SAnNdAB/kByu1G93mgRcFiDSBYEVp0NPKAMBJGs=' 'sha256-TueWUqsK8vYUrl4SXyNFoRG/GLd2NupSDD+vCgyx+Xc=' 'sha256-kjV2HSsww+yfRAWYmFlMdcEE8y4zPlDPFqNAQREKnZY=' 'sha256-YbmtYpKMBbMGKs14E0PWo75IBdBDX5CWsDq8MpWEyHM=' 'sha256-PEfi/YDkr4fkYc7SRkb+ieyexelyTvSSDWa/anqiya4=' 'sha256-FrDh0zGhibZ+qfMJ6Hvp8kbtZvlXjwW1dmGtdg9e28w=' 'sha256-bCtiv6upAhljIMpdaxHlL76MmcEJI2Rl/RLjGsh9X1o=' 'sha256-sJi1b0wPj8KtT87EkPfQb8HU96/6hjeK2E0EMvtANik=' 'sha256-Y2FGg04wMlMj0PgZSh71EUj3g21aJEHAeN/DpOC2xBY=' 'sha256-i6QaxhaxBUTzhVqdIfrumXQ2cwVgOoTpDCL9Xl6te04=' 'sha256-9rSUTMHr4pJbIUGV/B8xp6heILce4eA1XIWu+EvMxBU=' 'sha256-LLsxsGq6wsbiveWC8gdnwyoogvx0Ixde0yAkqaI42QU=' 'sha256-oLU3qzblTX8vLwb91SMhEymHWHexmH8Mwz6oUkG3olU=' 'sha256-FfqkCysOcHb0NmYm3jGvgIjb3sI5rd5v6ycjBdE9/SU='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-src https://www.google.com https://maps.google.com; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType application/json "access plus 1 week"
  ExpiresByType application/xml "access plus 1 week"
  ExpiresByType text/xml "access plus 1 week"
  ExpiresByType text/plain "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/avif "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  # HTML oraz pliki kodu sa zawsze ponownie sprawdzane przez przegladarke.
  # Zapobiega to utrzymywaniu starego mobilnego CSS/JS po wdrozeniu.
  <FilesMatch "\.(html|htm|css|js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Obrazy i dokumenty moga pozostac w cache; ich adresy w HTML maja numer wersji.
  <FilesMatch "\.(png|jpg|jpeg|webp|avif|svg|ico|pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
